/* pages/addCourse/addCourse.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 20rpx 30rpx !important;
  padding-bottom: 60rpx !important;
  height: auto !important;
  display: block !important;
  align-items: stretch !important;
  justify-content: flex-start !important;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.week-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #07c160;
  font-weight: normal;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: #444;
  flex-shrink: 0;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 32rpx;
  color: #333;
  margin-left: 30rpx;
}

.picker {
  font-size: 32rpx;
  color: #333;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  min-width: 140rpx;
  text-align: center;
}

.week-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.week-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.week-item.selected {
  background: #07c160;
  color: #fff;
}

.week-summary {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  transition: all 0.2s;
  border: 4rpx solid transparent;
}

.color-item.selected {
  border-color: #333;
  transform: scale(1.1);
}

.actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-save {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx;
}

.btn-delete {
  background: #fff;
  color: #ee0a24;
  border: 2rpx solid #ee0a24;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx;
}

/* ======= 自定义 picker 弹窗 ======= */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.picker-panel {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel {
  font-size: 30rpx;
  color: #999;
}

.picker-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.picker-confirm {
  font-size: 30rpx;
  color: #07c160;
  font-weight: bold;
}

.picker-body {
  max-height: 60vh;
  padding: 20rpx 0;
}

.picker-item {
  padding: 28rpx 30rpx;
  text-align: center;
  font-size: 34rpx;
  color: #666;
  border-bottom: 1rpx solid #f8f8f8;
}

.picker-item.selected {
  color: #07c160;
  font-weight: bold;
  background: #f5fff8;
}
