<!--pages/addCourse/addCourse.wxml-->
<wxs module="weekUtil">
  module.exports = {
    isSelected: function(weeks, week) {
      return weeks.indexOf(week) > -1
    }
  }
</wxs>

<navigation-bar title="{{isEdit ? '编辑课程' : '添加课程'}}" back="{{true}}" color="{{darkModeActive ? 'white' : 'black'}}" background="{{darkModeActive ? '#1a1a1a' : '#FFF'}}" ext-class="{{darkModeActive ? 'dark' : ''}}"></navigation-bar>

<scroll-view class="scrollarea {{darkModeActive ? 'dark' : ''}}" scroll-y type="list">
  <view class="container {{darkModeActive ? 'dark' : ''}}">
    <!-- 基本信息 -->
    <view class="section">
      <view class="section-title">基本信息</view>

      <view class="form-item">
        <text class="label">课程名称</text>
        <input class="input" placeholder="请输入课程名称" value="{{courseName}}" bindinput="onCourseNameInput" />
      </view>

      <view class="form-item">
        <text class="label">授课教师</text>
        <input class="input" placeholder="请输入教师姓名" value="{{teacher}}" bindinput="onTeacherInput" />
      </view>

      <view class="form-item">
        <text class="label">上课地点</text>
        <input class="input" placeholder="请输入教室地点" value="{{location}}" bindinput="onLocationInput" />
      </view>
    </view>

    <!-- 上课时间 -->
    <view class="section">
      <view class="section-title">上课时间</view>

      <view class="form-item">
        <text class="label">星期</text>
        <view class="picker" bindtap="showDayPicker">
          {{dayOptions[day - 1]}}
        </view>
      </view>

      <view class="form-item">
        <text class="label">开始节次</text>
        <view class="picker" bindtap="showStartLessonPicker">
          第 {{startLesson}} 节
        </view>
      </view>

      <view class="form-item">
        <text class="label">连续节数</text>
        <view class="picker" bindtap="showLessonCountPicker">
          {{lessonCount}} 节
        </view>
      </view>
    </view>

    <!-- 上课周次 -->
    <view class="section">
      <view class="section-title">
        <text>上课周次</text>
        <view class="week-actions">
          <text class="action-btn" bindtap="onSelectAllWeeks">全选</text>
          <text class="action-btn" bindtap="onOddWeeks">单周</text>
          <text class="action-btn" bindtap="onEvenWeeks">双周</text>
          <text class="action-btn" bindtap="onClearWeeks">清空</text>
        </view>
      </view>

      <view class="week-grid">
        <view
          wx:for="{{weekOptions}}"
          wx:key="*this"
          class="week-item {{weekUtil.isSelected(weeks, item) ? 'selected' : ''}}"
          data-week="{{item}}"
          bindtap="onWeekToggle"
        >
          {{item}}
        </view>
      </view>

      <view class="week-summary" wx:if="{{weeks.length > 0}}">
        已选择 {{weeks.length}} 周
      </view>
    </view>

    <!-- 课程颜色 -->
    <view class="section">
      <view class="section-title">课程颜色</view>
      <view class="color-grid">
        <view
          wx:for="{{colorOptions}}"
          wx:key="*this"
          class="color-item {{color === item ? 'selected' : ''}}"
          style="background-color: {{item}}"
          data-color="{{item}}"
          bindtap="onColorSelect"
        ></view>
      </view>
    </view>

    <!-- 课程备注 -->
    <view class="section">
      <view class="section-title">课程备注</view>
      <textarea
        class="notes-input"
        placeholder="请输入课程备注信息（如作业、考试提醒等）"
        value="{{notes}}"
        maxlength="200"
        bindinput="onNotesInput"
      />
      <view class="notes-count">{{notes.length || 0}}/200</view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="btn-save" bindtap="onSave">{{isEdit ? '保存修改' : '添加课程'}}</button>
      <button class="btn-delete" wx:if="{{isEdit}}" bindtap="onDelete">删除课程</button>
    </view>
  </view>
</scroll-view>

<!-- 自定义 picker 弹窗 -->
<view class="picker-mask" wx:if="{{showPicker}}" bindtap="hidePicker">
  <view class="picker-panel" catchtap="stopBubbling">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hidePicker">取消</text>
      <text class="picker-title">{{pickerTitle}}</text>
      <text class="picker-confirm" bindtap="confirmPicker">确定</text>
    </view>
    <scroll-view class="picker-body" scroll-y>
      <view
        wx:for="{{pickerOptions}}"
        wx:key="value"
        class="picker-item {{pickerValue === item.value ? 'selected' : ''}}"
        data-value="{{item.value}}"
        bindtap="onPickerItemTap"
      >{{item.label}}</view>
    </scroll-view>
  </view>
</view>
