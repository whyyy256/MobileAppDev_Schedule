/* pages/index/index.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 周次切换 */
.week-switcher {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.week-nav {
  padding: 10rpx 20rpx;
  font-size: 40rpx;
  color: #07c160;
}

.week-display {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 10rpx 40rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 课程表容器 */
.schedule-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 星期标题 */
.schedule-header {
  display: grid;
  background: #f8f8f8;
  border-bottom: 2rpx solid #e8e8e8;
}

.header-cell {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 课程内容 */
.schedule-content {
  flex: 1;
  overflow: hidden;
}

.schedule-grid {
  display: grid;
  min-height: 100%;
}

/* 节次列 */
.lesson-numbers {
  display: flex;
  flex-direction: column;
  background: #f8f8f8;
  border-right: 2rpx solid #e8e8e8;
}

.lesson-number {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  border-bottom: 2rpx solid #e8e8e8;
}

/* 课程格子 */
.schedule-cells {
  display: flex;
  flex: 1;
}

.day-column {
  flex: 1;
  display: grid;
  grid-auto-rows: 120rpx;
  border-right: 2rpx solid #e8e8e8;
}

.day-column:last-child {
  border-right: none;
}

.cell {
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 2rpx solid #e8e8e8;
  position: relative;
  min-height: 120rpx;
}

.cell.has-course {
  padding: 8rpx;
  border-radius: 8rpx;
  margin: 4rpx;
}

.cell-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #fff;
  text-align: center;
}

.cell-name {
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.cell-location {
  font-size: 20rpx;
  opacity: 0.9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.add-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}
