/* pages/index/index.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 0 !important;
  justify-content: flex-start !important;
  align-items: stretch !important;
  height: auto !important;
}

/* ======= 导航栏左侧设置入口 ======= */
.nav-left {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 16rpx;
}

.nav-settings-icon {
  width: 44rpx;
  height: 44rpx;
}

/* ======= 导航栏中间周次切换 ======= */
.nav-center {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.nav-week-nav {
  width: 60rpx;
  font-size: 42rpx;
  color: #07c160;
  line-height: 1;
  font-weight: bold;
  text-align: center;
}

.nav-week-nav.disabled {
  color: #ccc;
}

.nav-week-text {
  width: 160rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.nav-week-current {
  color: #07c160;
}

.nav-right {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 10rpx;
}

.nav-toggle {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

/* ======= 自定义周次选择弹窗 ======= */
.week-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.week-picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.week-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel,
.picker-confirm {
  font-size: 34rpx;
  line-height: 1;
}

.picker-cancel {
  color: #888;
}

.picker-confirm {
  color: #07c160;
}

.week-picker-list {
  height: 420rpx;
}

.week-picker-item {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 34rpx;
  color: #333;
}

.week-picker-item.active {
  color: #07c160;
  font-weight: 700;
}

/* ======= 时间编辑弹窗 ======= */
.time-edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.time-edit-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.time-edit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.time-edit-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.time-edit-body {
  padding: 20rpx 32rpx 40rpx;
}

.time-edit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.time-edit-label {
  font-size: 30rpx;
  color: #555;
}

.time-edit-value {
  font-size: 34rpx;
  color: #07c160;
  font-weight: 600;
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  min-width: 120rpx;
  text-align: center;
}

/* ======= 自定义时间选择弹窗 ======= */
.time-select-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 210;
}

.time-select-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.time-select-body {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 420rpx;
  padding: 20rpx 0;
}

.time-select-col {
  width: 180rpx;
  height: 100%;
}

.time-select-colon {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  padding: 0 30rpx;
}

.time-select-item {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 34rpx;
  color: #333;
}

.time-select-item.active {
  color: #07c160;
  font-weight: 700;
}

/* ======= 课程表容器 ======= */
.schedule-wrap {
  flex: 1;
  background: #fff;
  border-radius: 14rpx 14rpx 0 0;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ======= 顶部行（角落 + 星期标题） ======= */
.table-top {
  display: flex;
  flex-shrink: 0;
  border-bottom: 2rpx solid #e0e0e0;
  background: #fafafa;
  z-index: 20;
}

.corner-cell {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #bbb;
  border-right: 1rpx solid #e8e8e8;
  background: #fafafa;
}

.header-scroll {
  flex: 1;
  overflow: hidden;
}

.header-days {
  display: flex;
}

.day-cell {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #e8e8e8;
}

.day-cell:last-child {
  border-right: none;
}

.day-date {
  font-size: 20rpx;
  color: #999;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.day-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.day-status {
  font-size: 18rpx;
  color: #ff6b6b;
  line-height: 1.2;
  margin-bottom: 2rpx;
  padding: 0 6rpx;
  border-radius: 4rpx;
  background: rgba(255, 107, 107, 0.12);
}

.day-cell-holiday {
  background: #fff5f5;
}

.day-cell-holiday .day-name,
.day-cell-holiday .day-date {
  color: #ff6b6b;
}

.day-cell-workday {
  background: #f5fff5;
}

.day-cell-workday .day-name,
.day-cell-workday .day-date,
.day-cell-workday .day-status {
  color: #07c160;
}

.day-cell-workday .day-status {
  background: rgba(7, 193, 96, 0.12);
}

/* ======= 底部区域（单一滚动容器） ======= */
.table-bottom {
  flex: 1;
  overflow: hidden;
}

.table-inner {
  display: flex;
  flex-direction: column;
  min-height: 100%;
}

.table-section {
  display: flex;
}

/* 固定左侧时间列 */
.time-col {
  flex-shrink: 0;
  border-right: 1rpx solid #e8e8e8;
  background: #fff;
  position: sticky;
  left: 0;
  z-index: 15;
}

.time-inner {
  display: flex;
  flex-direction: column;
}

.time-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
  gap: 2rpx;
}

.t-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #555;
}

.t-time {
  font-size: 16rpx;
  color: #aaa;
}

/* 右侧网格 */
.grid-area {
  display: flex;
}

/* 午休 / 晚休条带 */
.break-band {
  width: 100%;
  flex-shrink: 0;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.break-band text {
  font-size: 22rpx;
  color: #999;
}

.day-col {
  flex-shrink: 0;
  position: relative;
  border-right: 1rpx solid #e8e8e8;
}

.day-col:last-child {
  border-right: none;
}

/* 空格子辅助线 */
.cell-line {
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.cell-line-selected {
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-line-plus {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

/* ======= 课程卡片 ======= */
.course-card {
  position: absolute;
  left: 3rpx;
  right: 3rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 4rpx;
  box-sizing: border-box;
  overflow: hidden;
  z-index: 5;
}

.course-card-gray {
  filter: grayscale(100%);
  opacity: 0.45;
}

.c-name {
  font-size: 21rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.c-loc {
  font-size: 17rpx;
  color: rgba(255,255,255,0.88);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* ======= 添加按钮 ======= */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.4);
  z-index: 100;
}

/* ======= 导入按钮（左下角白色圆形） ======= */
.import-btn {
  position: fixed;
  left: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
  z-index: 100;
}

.import-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
}

.import-arrow {
  position: absolute;
  top: 0;
  left: 18rpx;
  width: 8rpx;
  height: 24rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.import-arrow::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: -9rpx;
  width: 18rpx;
  height: 18rpx;
  border-right: 8rpx solid #07c160;
  border-bottom: 8rpx solid #07c160;
  transform: rotate(45deg);
}

.import-tray {
  position: absolute;
  bottom: 0;
  left: 2rpx;
  width: 40rpx;
  height: 8rpx;
  background: #07c160;
  border-radius: 4rpx;
}

/* ======= 课程详情弹窗 ======= */
.course-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.course-detail-panel {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  border-left: 12rpx solid #07c160;
  box-sizing: border-box;
}

.course-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.course-detail-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
}

.course-detail-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 10rpx;
}

.course-detail-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.course-detail-label {
  width: 100rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.course-detail-value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
}

.course-detail-actions {
  margin-top: 40rpx;
  display: flex;
  justify-content: flex-end;
}

.course-detail-btn {
  padding: 16rpx 40rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
}

.course-detail-btn.edit {
  background: #07c160;
  color: #fff;
}

/* ======= 日视图 ======= */
.day-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.day-view-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.day-view-nav {
  font-size: 40rpx;
  color: #07c160;
  padding: 0 40rpx;
  font-weight: bold;
}

.day-view-nav.disabled {
  color: #ddd;
}

.day-view-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.day-view-date {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
  margin-bottom: 4rpx;
}

.day-view-list {
  flex: 1;
  padding: 20rpx;
}

.day-view-empty {
  text-align: center;
  padding: 80rpx 0;
  font-size: 30rpx;
  color: #999;
}

.day-view-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border-left: 8rpx solid #07c160;
}

.day-view-time {
  width: 160rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.day-view-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
}

.day-view-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.day-view-meta {
  font-size: 26rpx;
  color: #999;
}
