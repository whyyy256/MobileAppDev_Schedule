<!--pages/index/index.wxml-->
<navigation-bar
  title=""
  back="{{false}}"
  color="{{darkModeActive ? 'white' : 'black'}}"
  background="{{darkModeActive ? '#1a1a1a' : '#FFF'}}"
  ext-class="{{darkModeActive ? 'dark' : ''}}"
>
  <view slot="left" class="nav-left">
    <image class="nav-settings-icon" src="/assets/icons/settings.svg" mode="aspectFit" bindtap="onSettingsTap" />
    <image class="nav-share-icon" src="/assets/icons/share.svg" mode="aspectFit" bindtap="onShareTap" />
  </view>
  <view slot="center" class="nav-center">
    <text class="nav-week-nav {{currentWeek <= 1 ? 'disabled' : ''}}" bindtap="onPrevWeek">‹</text>
    <view class="nav-week-text {{currentWeek === todayWeek ? 'nav-week-current' : ''}}" bindtap="showWeekPicker">第 {{currentWeek}} 周</view>
    <text class="nav-week-nav {{currentWeek >= totalWeeks ? 'disabled' : ''}}" bindtap="onNextWeek">›</text>
  </view>
  <view slot="right" class="nav-right">
    <text class="nav-toggle" bindtap="onToggleView">{{viewMode === 'week' ? '日' : '周'}}</text>
  </view>
</navigation-bar>

<!-- 自定义周次选择弹窗 -->
<view class="week-picker-mask" wx:if="{{showWeekPicker}}" bindtap="hideWeekPicker">
  <view class="week-picker-panel" catchtap="stopBubbling">
    <view class="week-picker-header">
      <text class="picker-cancel" bindtap="hideWeekPicker">取消</text>
      <text class="picker-confirm" bindtap="confirmWeek">确定</text>
    </view>
    <scroll-view class="week-picker-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{weekOptions}}"
        wx:key="*this"
        class="week-picker-item {{tempWeek === index + 1 ? 'active' : ''}}"
        data-week="{{index + 1}}"
        bindtap="onWeekItemTap"
      >{{item}}</view>
    </scroll-view>
  </view>
</view>

<!-- 时间编辑弹窗 -->
<view class="time-edit-mask" wx:if="{{showTimeEdit}}" bindtap="hideTimeEdit">
  <view class="time-edit-panel" catchtap="stopBubbling">
    <view class="time-edit-header">
      <text class="picker-cancel" bindtap="hideTimeEdit">取消</text>
      <text class="time-edit-title">第 {{editLesson}} 节课</text>
      <text class="picker-confirm" bindtap="confirmTimeEdit">确定</text>
    </view>
    <view class="time-edit-body">
      <view class="time-edit-row" bindtap="onEditStartTap">
        <text class="time-edit-label">上课时间</text>
        <view class="time-edit-value">{{editStart}}</view>
      </view>
      <view class="time-edit-row" bindtap="onEditEndTap">
        <text class="time-edit-label">下课时间</text>
        <view class="time-edit-value">{{editEnd}}</view>
      </view>
    </view>
  </view>
</view>

<!-- 自定义时间选择弹窗 -->
<view class="time-select-mask" wx:if="{{showTimeSelect}}" bindtap="hideTimeSelect">
  <view class="time-select-panel" catchtap="stopBubbling">
    <view class="time-edit-header">
      <text class="picker-cancel" bindtap="hideTimeSelect">取消</text>
      <text class="time-edit-title">选择时间</text>
      <text class="picker-confirm" bindtap="confirmTimeSelect">确定</text>
    </view>
    <view class="time-select-body">
      <scroll-view class="time-select-col" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{hours}}"
          wx:key="*this"
          class="time-select-item {{selectHour === item ? 'active' : ''}}"
          data-value="{{item}}"
          data-type="hour"
          bindtap="onTimeSelectItemTap"
        >{{item}}</view>
      </scroll-view>
      <text class="time-select-colon">:</text>
      <scroll-view class="time-select-col" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{minutes}}"
          wx:key="*this"
          class="time-select-item {{selectMinute === item ? 'active' : ''}}"
          data-value="{{item}}"
          data-type="minute"
          bindtap="onTimeSelectItemTap"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>
</view>

<!-- 课程详情弹窗 -->
<view class="course-detail-mask" wx:if="{{showCourseDetail}}" bindtap="hideCourseDetail">
  <view class="course-detail-panel" catchtap="stopBubbling" style="border-left-color: {{courseDetail.color}};">
    <view class="course-detail-header">
      <text class="course-detail-name">{{courseDetail.name}}</text>
      <text class="course-detail-close" bindtap="hideCourseDetail">×</text>
    </view>
    <view class="course-detail-body">
      <view class="course-detail-row" wx:if="{{courseDetail.teacher}}">
        <text class="course-detail-label">教师</text>
        <text class="course-detail-value">{{courseDetail.teacher}}</text>
      </view>
      <view class="course-detail-row" wx:if="{{courseDetail.location}}">
        <text class="course-detail-label">地点</text>
        <text class="course-detail-value">{{courseDetail.location}}</text>
      </view>
      <view class="course-detail-row">
        <text class="course-detail-label">时间</text>
        <text class="course-detail-value">{{dayHeaders[courseDetail.day - 1]}} 第 {{courseDetail.startLesson}}-{{courseDetail.startLesson + courseDetail.lessonCount - 1}} 节</text>
      </view>
      <view class="course-detail-row">
        <text class="course-detail-label">周次</text>
        <text class="course-detail-value">{{courseDetail.weeksText}}</text>
      </view>
      <view class="course-detail-row" wx:if="{{courseDetail.notes}}">
        <text class="course-detail-label">备注</text>
        <text class="course-detail-value">{{courseDetail.notes}}</text>
      </view>
    </view>
    <view class="course-detail-actions">
      <view class="course-detail-btn edit" bindtap="onEditCourseDetail">编辑课程</view>
    </view>
  </view>
</view>

<view class="container {{darkModeActive ? 'dark' : ''}}">
  <!-- 课程表 -->
  <view
    class="schedule-wrap"
    wx:if="{{viewMode === 'week'}}"
    style="{{backgroundImage ? 'background-image: url(' + backgroundImage + '); background-size: cover; background-position: center;' : ''}}"
  >

    <!-- 顶部：固定角落 + 横向滚动的星期标题 -->
    <view class="table-top">
      <view class="corner-cell" style="width:{{timeColWidth}}rpx; height:{{headerHeight}}rpx;"></view>
      <scroll-view
        class="header-scroll"
        scroll-x
        enhanced
        show-scrollbar="{{false}}"
        scroll-left="{{hScrollLeft}}"
        bindscroll="onHeaderScroll"
      >
        <view class="header-days">
          <view
          class="day-cell {{dayStatus[index] === 'holiday' ? 'day-cell-holiday' : ''}} {{dayStatus[index] === 'workday' ? 'day-cell-workday' : ''}}"
          wx:for="{{dayHeaders}}"
          wx:key="*this"
          style="width:{{dayColWidth}}rpx; height:{{headerHeight}}rpx;"
        >
          <text class="day-status" wx:if="{{dayStatus[index] === 'holiday' || dayStatus[index] === 'workday'}}">{{dayStatus[index] === 'holiday' ? '休' : '班'}}</text>
          <text class="day-date">{{dayDateTexts[index]}}</text>
          <text class="day-name">{{item}}</text>
        </view>
        </view>
      </scroll-view>
    </view>

    <!-- 底部：单一滚动区域，按上午/下午/晚上分节，节间插入午休/晚休条带 -->
    <scroll-view
      class="table-bottom"
      scroll-x
      scroll-y
      enhanced
      enable-flex
      show-scrollbar="{{false}}"
      scroll-left="{{gScrollLeft}}"
      bindscroll="onGridScroll"
      bindtouchstart="onTableTouchStart"
      bindtouchend="onTableTouchEnd"
    >
      <view class="table-inner">
        <block wx:for="{{sections}}" wx:key="key" wx:for-item="sec">
          <view class="table-section">
            <!-- 固定左侧时间列 -->
            <view class="time-col" style="width:{{timeColWidth}}rpx;">
              <view class="time-inner">
                <view
                  wx:for="{{sec.lessonTimes}}"
                  wx:key="lesson"
                  class="time-cell"
                  style="height:{{cellHeight}}rpx; width:{{timeColWidth}}rpx;"
                  data-lesson="{{item.lesson}}"
                  bindtap="onTimeCellTap"
                >
                  <text class="t-num">{{item.lesson}}</text>
                  <text class="t-time">{{item.start}}</text>
                  <text class="t-time">{{item.end}}</text>
                </view>
              </view>
            </view>

            <!-- 右侧网格 -->
            <view class="grid-area">
              <view
                class="day-col"
                wx:for="{{sec.dayColumns}}"
                wx:for-item="dayCol"
                wx:key="day"
                style="width:{{dayColWidth}}rpx;"
              >
                <!-- 空格子辅助线 -->
                <view
                  wx:for="{{sec.lessonTimes}}"
                  wx:for-item="lt"
                  wx:for-index="idx"
                  wx:key="idx"
                  class="cell-line {{selectedCell && selectedCell.day === dayCol.day && selectedCell.lesson === lt.lesson ? 'cell-line-selected' : ''}}"
                  style="height:{{cellHeight}}rpx;"
                  data-day="{{dayCol.day}}"
                  data-lesson="{{lt.lesson}}"
                  bindtap="onEmptyCellTap"
                >
                  <text wx:if="{{selectedCell && selectedCell.day === dayCol.day && selectedCell.lesson === lt.lesson}}" class="cell-line-plus">+</text>
                </view>

                <!-- 课程卡片 -->
                <view
                  wx:for="{{dayCol.courses}}"
                  wx:for-item="c"
                  wx:key="id"
                  class="course-card {{c.isCurrentWeek ? '' : 'course-card-gray'}}"
                  style="top:{{c.top}}rpx; height:{{c.height}}rpx; background:{{c.color}}; z-index:{{c.isCurrentWeek ? 10 : 5}};"
                  data-course="{{c}}"
                  catchtap="onCourseTap"
                >
                  <view class="c-name">{{c.name}}</view>
                  <text class="c-loc" wx:if="{{c.location}}">@{{c.location}}</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 午休 / 晚休条带 -->
          <view
            wx:if="{{sec.breakName}}"
            class="break-band"
            style="height:{{cellHeight / 3}}rpx;"
          >
            <text>{{sec.breakName}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- 日视图 -->
  <view class="day-view" wx:if="{{viewMode === 'day'}}">
    <view class="day-view-header">
      <text class="day-view-nav {{currentDay <= 1 ? 'disabled' : ''}}" bindtap="onPrevDay">‹</text>
      <view class="day-view-title">
        <text class="day-view-date">{{dayViewDate}}</text>
        <text>{{dayHeaders[currentDay - 1]}}</text>
      </view>
      <text class="day-view-nav {{currentDay >= showDays ? 'disabled' : ''}}" bindtap="onNextDay">›</text>
    </view>
    <scroll-view class="day-view-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{dayViewCourses.length === 0}}" class="day-view-empty">{{dayViewIsHoliday ? '今日放假' : '今日无课'}}</view>
      <view
        wx:for="{{dayViewCourses}}"
        wx:key="id"
        class="day-view-item"
        style="border-left-color: {{item.color}};"
        data-course="{{item}}"
        bindtap="onCourseTap"
      >
        <text class="day-view-time">{{item.timeText}}</text>
        <view class="day-view-info">
          <text class="day-view-name">{{item.name}}</text>
          <text class="day-view-meta" wx:if="{{item.teacher || item.location}}">
            {{item.teacher}}{{item.teacher && item.location ? ' · ' : ''}}{{item.location ? '@' + item.location : ''}}
          </text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="onAddCourse">+</view>

  <!-- 导入按钮 -->
  <view class="import-btn" bindtap="onImportTap">
    <view class="import-icon">
      <view class="import-arrow"></view>
      <view class="import-tray"></view>
    </view>
  </view>
</view>

<!-- 分享卡片 canvas（离屏绘制） -->
<canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>

<!-- 分享卡片预览弹窗 -->
<view class="share-mask" wx:if="{{showShareCard}}" bindtap="hideShareCard">
  <view class="share-panel" catchtap="stopBubbling">
    <view class="share-header">
      <text class="share-title">课程表分享卡片</text>
      <text class="share-close" bindtap="hideShareCard">×</text>
    </view>
    <image class="share-image" src="{{shareImagePath}}" mode="widthFix" wx:if="{{shareImagePath}}" />
    <view class="share-loading" wx:if="{{!shareImagePath}}">生成中...</view>
    <view class="share-actions">
      <view class="share-btn primary" bindtap="onShareToFriend">分享给好友</view>
      <view class="share-btn" bindtap="onSaveShareImage">保存到相册</view>
    </view>
  </view>
</view>
