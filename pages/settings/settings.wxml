<!--pages/settings/settings.wxml-->
<navigation-bar title="学期设置" back="{{true}}" color="{{darkModeActive ? 'white' : 'black'}}" background="{{darkModeActive ? '#1a1a1a' : '#FFF'}}" ext-class="{{darkModeActive ? 'dark' : ''}}"></navigation-bar>

<scroll-view class="scrollarea {{darkModeActive ? 'dark' : ''}}" scroll-y type="list">
  <view class="container {{darkModeActive ? 'dark' : ''}}">

    <!-- 当前学期 -->
    <view class="section">
      <view class="section-title">当前学期</view>

      <view class="form-item">
        <text class="label">学期名称</text>
        <input class="input" placeholder="如：2024-2025学年第一学期" value="{{semesterName}}" bindinput="onNameInput" />
      </view>

      <view class="form-item">
        <text class="label">开学日期</text>
        <view class="picker" data-mode="current" bindtap="openDatePicker">{{startDate || '请选择'}}</view>
      </view>

      <view class="form-item">
        <text class="label">学期总周数</text>
        <input class="input number" type="number" value="{{totalWeeks}}" bindinput="onWeeksInput" />
      </view>

      <view class="form-item">
      <text class="label">显示周末</text>
      <switch checked="{{showWeekend}}" bindchange="onWeekendChange" />
    </view>
  </view>

  <!-- 节假日 / 调休 -->
  <view class="section">
    <view class="section-title">节假日 / 调休</view>

    <view class="form-item">
      <text class="label">已设置</text>
      <view class="picker">
        节假日 {{holidayConfig.holidays.length}} 天 · 调休 {{holidayConfig.workdays.length}} 天
      </view>
    </view>

    <view class="btn" bindtap="showHolidayImportDialog">导入内置法定节假日</view>
    <view class="btn" data-mode="holiday" bindtap="openDatePicker">手动添加节假日</view>
    <view class="btn" data-mode="workday" bindtap="openDatePicker">手动添加调休上班日</view>
    <view class="btn" bindtap="clearHolidayConfig" style="color:#ff6b6b">清空配置</view>

    <view wx:if="{{displayHolidays.length > 0}}" class="holiday-list">
      <view class="holiday-title">节假日</view>
      <view wx:for="{{displayHolidays}}" wx:key="date" class="holiday-item" wx:if="{{index < 4 || showAllHolidays}}">
        <text>{{item.date}}</text>
        <text class="holiday-delete" data-date="{{item.date}}" bindtap="deleteHoliday">删除</text>
      </view>
      <view wx:if="{{displayHolidays.length > 4}}" class="holiday-toggle" bindtap="toggleHolidays">
        {{showAllHolidays ? '收起' : '展开'}}
      </view>
    </view>

    <view wx:if="{{displayWorkdays.length > 0}}" class="holiday-list">
      <view class="holiday-title">调休上班日</view>
      <view wx:for="{{displayWorkdays}}" wx:key="date" class="holiday-item" wx:if="{{index < 4 || showAllWorkdays}}">
        <text>{{item.date}}</text>
        <text class="makeup-text">{{item.makeupText}}</text>
        <view class="holiday-actions">
          <text class="holiday-edit" data-date="{{item.date}}" bindtap="setWorkdayMakeup">修改</text>
          <text class="holiday-delete" data-date="{{item.date}}" bindtap="deleteWorkday">删除</text>
        </view>
      </view>
      <view wx:if="{{displayWorkdays.length > 4}}" class="holiday-toggle" bindtap="toggleWorkdays">
        {{showAllWorkdays ? '收起' : '展开'}}
      </view>
    </view>
  </view>

  <!-- 数据备份 -->
  <view class="section">
    <view class="section-title">数据备份</view>
    <view class="btn" bindtap="exportBackup">导出备份（分享文件）</view>
  </view>

  <!-- 一天有几节课 -->
    <view class="section">
      <view class="section-title">每天课程节数</view>

      <view class="form-item">
        <text class="label">上午节数</text>
        <input class="input number" type="number" value="{{morning}}" bindinput="onMorningInput" />
      </view>

      <view class="form-item">
        <text class="label">下午节数</text>
        <input class="input number" type="number" value="{{afternoon}}" bindinput="onAfternoonInput" />
      </view>

      <view class="form-item">
        <text class="label">晚上节数</text>
        <input class="input number" type="number" value="{{evening}}" bindinput="onEveningInput" />
      </view>
    </view>

    <!-- 个性化设置 -->
    <view class="section">
      <view class="section-title">个性化设置</view>

      <view class="form-item form-item-vertical">
        <view class="label-row">
          <text class="label">课程表背景图片</text>
          <view class="picker" wx:if="{{!backgroundImage}}" bindtap="onChooseBackgroundImage">选择图片</view>
          <view class="picker danger" wx:if="{{backgroundImage}}" bindtap="onClearBackgroundImage">清除</view>
        </view>
        <view class="bg-preview-wrap" wx:if="{{backgroundImage}}">
          <image class="bg-preview" src="{{backgroundImage}}" mode="aspectFill" bindtap="onChooseBackgroundImage" />
        </view>
      </view>

      <view class="form-item">
        <text class="label">深色模式</text>
        <view class="dark-mode-options">
          <view
            wx:for="{{darkModeOptions}}"
            wx:key="value"
            class="dark-mode-option {{darkMode === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onDarkModeChange"
          >{{item.label}}</view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="btn primary" bindtap="saveSettings">保存设置</view>
    <view class="btn" bindtap="showNewSemesterDialog">新建新学期</view>
    <view class="btn" bindtap="showHistoryDialog">切换学期</view>

  </view>
</scroll-view>

<!-- 自定义日期选择弹窗 -->
<view class="date-picker-mask" wx:if="{{showDatePicker}}" bindtap="hideDatePicker">
  <view class="date-picker-panel" catchtap="stopBubbling">
    <view class="date-picker-header">
      <text class="picker-cancel" bindtap="hideDatePicker">取消</text>
      <text class="date-picker-title">选择日期</text>
      <text class="picker-confirm" bindtap="confirmDatePicker">确定</text>
    </view>
    <view class="date-picker-body">
      <scroll-view class="date-picker-col" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{years}}"
          wx:key="*this"
          class="date-picker-item {{pickerYear === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="onYearSelect"
        >{{item}}年</view>
      </scroll-view>
      <scroll-view class="date-picker-col" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{months}}"
          wx:key="*this"
          class="date-picker-item {{pickerMonth === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="onMonthSelect"
        >{{item}}月</view>
      </scroll-view>
      <scroll-view class="date-picker-col" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{days}}"
          wx:key="*this"
          class="date-picker-item {{pickerDay === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="onDaySelect"
        >{{item}}日</view>
      </scroll-view>
    </view>
  </view>
</view>

<!-- 导入法定节假日弹窗 -->
<view class="dialog-mask" wx:if="{{showHolidayImport}}" bindtap="hideHolidayImportDialog">
  <view class="dialog-panel" catchtap="stopBubbling">
    <view class="dialog-title">导入法定节假日</view>
    <view class="dialog-body">
      <view
        wx:for="{{builtinHolidayYears}}"
        wx:key="*this"
        class="dialog-row"
        data-year="{{item}}"
        bindtap="importBuiltinHolidays"
      >
        <text>{{item}} 年</text>
        <text class="dialog-row-arrow">›</text>
      </view>
    </view>
    <view class="dialog-actions single">
      <view class="dialog-btn cancel" bindtap="hideHolidayImportDialog">取消</view>
    </view>
  </view>
</view>

<!-- 调休上班日补课周几选择弹窗 -->
<view class="dialog-mask" wx:if="{{showMakeupDayPicker}}" bindtap="hideMakeupDayPicker">
  <view class="dialog-panel" catchtap="stopBubbling">
    <view class="dialog-title">选择补周几的课</view>
    <view class="dialog-body">
      <view
        wx:for="{{makeupDayOptions}}"
        wx:key="value"
        class="dialog-row"
        data-value="{{item.value}}"
        bindtap="selectMakeupDay"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
    <view class="dialog-actions single">
      <view class="dialog-btn cancel" bindtap="hideMakeupDayPicker">取消</view>
    </view>
  </view>
</view>

<!-- 新建学期弹窗 -->
<view class="dialog-mask" wx:if="{{showNewSemester}}" bindtap="hideNewSemesterDialog">
  <view class="dialog-panel" catchtap="stopBubbling">
    <view class="dialog-title">新建新学期</view>
    <view class="dialog-body">
      <view class="dialog-row">
        <text class="dialog-label">学期名称</text>
        <input class="dialog-input" placeholder="请输入学期名称" value="{{newName}}" bindinput="onNewNameInput" />
      </view>
      <view class="dialog-row">
        <text class="dialog-label">开学日期</text>
        <view class="dialog-picker" data-mode="new" bindtap="openDatePicker">{{newStartDate}}</view>
      </view>
      <view class="dialog-row">
        <text class="dialog-label">总周数</text>
        <input class="dialog-input number" type="number" value="{{newTotalWeeks}}" bindinput="onNewWeeksInput" />
      </view>
    </view>
    <view class="dialog-actions">
      <view class="dialog-btn cancel" bindtap="hideNewSemesterDialog">取消</view>
      <view class="dialog-btn confirm" bindtap="confirmNewSemester">确定</view>
    </view>
  </view>
</view>

<!-- 历史学期弹窗 -->
<view class="dialog-mask" wx:if="{{showHistory}}" bindtap="hideHistoryDialog">
  <view class="dialog-panel history-panel" catchtap="stopBubbling">
    <view class="dialog-title">历史学期</view>
    <scroll-view class="history-list" scroll-y>
      <view
        wx:for="{{semesters}}"
        wx:key="id"
        class="history-item {{currentSemesterId === item.id ? 'current' : ''}}"
      >
        <view class="history-info" data-id="{{item.id}}" bindtap="onSwitchSemester">
          <text class="history-name">{{item.name}}</text>
          <text class="history-meta">{{item.startDate}} · 共 {{item.totalWeeks}} 周</text>
        </view>
        <view wx:if="{{currentSemesterId !== item.id}}" class="history-delete" data-id="{{item.id}}" bindtap="onDeleteSemester">删除</view>
      </view>
    </scroll-view>
    <view class="dialog-actions single">
      <view class="dialog-btn cancel" bindtap="hideHistoryDialog">关闭</view>
    </view>
  </view>
</view>
