/* pages/settings/settings.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 20rpx 30rpx !important;
  padding-bottom: 60rpx !important;
  height: auto !important;
  display: block !important;
  align-items: stretch !important;
  justify-content: flex-start !important;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  margin-left: 30rpx;
}

.input.number {
  min-width: 80rpx;
}

.picker {
  font-size: 28rpx;
  color: #333;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.btn {
  background: #fff;
  color: #333;
  font-size: 30rpx;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.btn.primary {
  background: #07c160;
  color: #fff;
  font-weight: bold;
}

/* ======= 弹窗 ======= */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.dialog-panel {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.history-panel {
  width: 86%;
  max-height: 70%;
  display: flex;
  flex-direction: column;
  top: 45%;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.dialog-body {
  margin-bottom: 20rpx;
}

.dialog-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.dialog-row:last-child {
  border-bottom: none;
}

.dialog-label {
  font-size: 28rpx;
  color: #666;
}

.dialog-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  margin-left: 20rpx;
}

.dialog-picker {
  font-size: 28rpx;
  color: #333;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.dialog-actions {
  display: flex;
  gap: 20rpx;
}

.dialog-actions.single {
  justify-content: center;
}

.dialog-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 10rpx;
  font-size: 30rpx;
}

.dialog-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.dialog-btn.confirm {
  background: #07c160;
  color: #fff;
}

.history-list {
  max-height: 400rpx;
  margin-bottom: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.history-name {
  font-size: 30rpx;
  color: #333;
}

.history-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* ======= 自定义日期选择弹窗 ======= */
.date-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 210;
}

.date-picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.date-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.date-picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.picker-cancel {
  font-size: 34rpx;
  color: #999;
}

.picker-confirm {
  font-size: 34rpx;
  color: #07c160;
}

.date-picker-body {
  display: flex;
  justify-content: center;
  height: 420rpx;
  padding: 20rpx 0;
}

.date-picker-col {
  width: 200rpx;
  height: 100%;
}

.date-picker-item {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 34rpx;
  color: #333;
}

.date-picker-item.active {
  color: #07c160;
  font-weight: 700;
}

.history-item.current .history-name {
  color: #07c160;
  font-weight: bold;
}

.history-delete {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 10rpx 20rpx;
}

/* ======= 节假日 / 调休列表 ======= */
.holiday-list {
  margin-top: 20rpx;
}

.holiday-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.holiday-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.holiday-item:last-child {
  border-bottom: none;
}

.holiday-delete {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 6rpx 16rpx;
}

.dialog-row-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.holiday-toggle {
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #07c160;
}

.makeup-text {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  flex: 1;
}

.holiday-actions {
  display: flex;
  align-items: center;
}

.holiday-edit {
  font-size: 26rpx;
  color: #07c160;
  padding: 6rpx 16rpx;
}
